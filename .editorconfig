# .editorconfig

# This file enforces consistent formatting across editors.
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.c]
indent_size = 4

[*.cpp]
indent_size = 4

[*.h]
indent_size = 4

[*.hpp]
indent_size = 4

[Makefile]
indent_style = tab
indent_size = 4

[*.sh]
indent_style = tab
indent_size = 4

[*.py]
indent_style = space
indent_size = 4